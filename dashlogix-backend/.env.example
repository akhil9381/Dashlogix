# =============================================================================
# DashLogix Backend Environment Configuration
# =============================================================================
# Copy this file to dashlogix-backend/.env and fill in your values

# =============================================================================
# SPLUNK CONFIGURATION (REQUIRED)
# =============================================================================

# Splunk server hostname or IP address
# Example: splunk.example.com or 192.168.1.100
SPLUNK_HOST=your-splunk-server.example.com

# Splunk REST API port (usually 8089)
SPLUNK_PORT=8089

# Connection scheme: https or http
# Note: Use https for remote servers, http for local/dev only
SPLUNK_SCHEME=https

# Splunk username (typically admin or a monitoring user)
SPLUNK_USERNAME=admin

# Splunk password (use a strong password in production)
SPLUNK_PASSWORD=your-splunk-password

# Default Splunk index to monitor
# Common values:
#   _internal - Splunk's internal logs (recommended for testing)
#   main - Default external data index
#   _audit - Audit logs
#   _introspection - System introspection
SPLUNK_INDEX=_internal

# Maximum logs to collect per query (1-1000)
# Higher values = more data, slower queries
# Recommended: 100-500
SPLUNK_COLLECT_LIMIT=200

# Time window for log collection
# Examples: -15m, -1h, -24h, -7d, -30d
# This determines how far back to look for logs
SPLUNK_EARLIEST=-24h

# =============================================================================
# MONGODB CONFIGURATION (REQUIRED)
# =============================================================================

# MongoDB connection string
# 
# LOCAL MONGODB:
# mongodb://localhost:27017/dashlogix
#
# MONGODB ATLAS (cloud):
# mongodb+srv://username:password@cluster.mongodb.net/dashlogix
# (Replace username, password, and cluster with your actual values)
#
# DOCKER:
# mongodb://host.docker.internal:27017/dashlogix
#
MONGO_URI=mongodb://localhost:27017/dashlogix

# =============================================================================
# SERVER CONFIGURATION (OPTIONAL)
# =============================================================================

# Server port (default: 5001)
# Note: Port 5000 is often occupied on Windows (AirPlay)
PORT=5001

# Auto collection interval in milliseconds
# How often to poll Splunk for new logs (default: 5000ms = 5 seconds)
# Minimum: 1000ms (1 second)
COLLECT_INTERVAL_MS=5000

# =============================================================================
# NODE ENVIRONMENT (OPTIONAL)
# =============================================================================

# Environment: development, staging, or production
NODE_ENV=development

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. REQUIRED FIELDS:
#    - All SPLUNK_* fields
#    - MONGO_URI
#
# 2. FOR MONGODB ATLAS:
#    - Create a cluster at mongodb.com
#    - Create a database user (Security → Database Access)
#    - Whitelist your IP (Security → Network Access)
#    - Get connection string (Clusters → Connect → Drivers)
#
# 3. FOR SPLUNK:
#    - Admin credentials or monitor role required
#    - REST API must be enabled (default)
#    - Network access required from your machine
#
# 4. SECURITY:
#    - Never commit .env to git (add to .gitignore)
#    - Use strong passwords in production
#    - Rotate credentials regularly
#    - Use secrets management for production
#
# 5. TROUBLESHOOTING:
#    - See REALTIME_MONITORING.md for detailed troubleshooting
#    - Check backend console output: node server.js
#    - Verify Splunk connectivity: curl command in docs
#
# =============================================================================

# =============================================================================
# ALERTING + SMTP (OPTIONAL)
# =============================================================================

# Scheduler tick for evaluating alert rules (milliseconds)
ALERT_TICK_MS=60000

# Default recipient if rule.emailTo is empty
ALERT_DEFAULT_TO=ops@example.com

# SMTP server configuration for email alerts
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=DashLogix Alerts <your-email@example.com>

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
# Real-time streaming poll interval in milliseconds
REALTIME_POLL_MS=3000

# Real-time search window per poll (example: -1m, -30s, -5m)
SPLUNK_REALTIME_EARLIEST=-1m
